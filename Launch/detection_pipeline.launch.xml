<?xml version="1.0"?>
<launch>
    <!-- Parameters -->
    <arg name="bag_file" default="$(find vehicle_detection)/data/rosbag.bag"/>
    <arg name="image_topic" default="/camera/image_raw"/>
    
    <!-- Extract images from rosbag (optional) -->
    <node name="image_extractor" pkg="vehicle_detection" type="extract_images.py" 
          output="screen" if="$(arg extract_images)">
        <param name="bag_file" value="$(arg bag_file)"/>
        <param name="image_topic" value="$(arg image_topic)"/>
        <param name="output_dir" value="$(find vehicle_detection)/extracted_images"/>
    </node>
    
    <!-- Vehicle Detection Node -->
    <node name="vehicle_detector" pkg="vehicle_detection" type="vehicle_detector.py" 
          output="screen">
        <param name="config_path" value="$(find vehicle_detection)/config/detector_config.yaml"/>
    </node>
    
    <!-- Detection UI -->
    <node name="detection_ui" pkg="vehicle_detection" type="detection_ui.py" 
          output="screen"/>
    
</launch>